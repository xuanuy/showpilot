# Copy to `secrets.env` and fill in real values. Never commit secrets.env.
# One Page ID + Page access token PER CHANNEL. Key = <UPPER_ID>_PAGE_ID / _TOKEN
# where UPPER_ID is the channel id uppercased with '-' -> '_'.
# Only fill in the channels you have actually created. See README -> Facebook setup.

DONGHUA_DECODED_PAGE_ID=
DONGHUA_DECODED_TOKEN=

QI_AND_SWORDS_PAGE_ID=
QI_AND_SWORDS_TOKEN=

DONGHUA_REALM_PAGE_ID=
DONGHUA_REALM_TOKEN=

XIANXIA_DAILY_PAGE_ID=
XIANXIA_DAILY_TOKEN=

CULTIVATION_CHRONICLES_PAGE_ID=
CULTIVATION_CHRONICLES_TOKEN=

IMMORTAL_PATH_PAGE_ID=
IMMORTAL_PATH_TOKEN=

DAO_OF_DONGHUA_PAGE_ID=
DAO_OF_DONGHUA_TOKEN=

HEAVENLY_DONGHUA_PAGE_ID=
HEAVENLY_DONGHUA_TOKEN=

# Qwen Cloud (qwencloud.com -> API Keys, starts with sk-). Enables automatic
# script writing (empty `## Script` sections) and `mode: wan` generative video.
DASHSCOPE_API_KEY=

# Optional fallback: script writing via Claude if no DASHSCOPE_API_KEY.
# ANTHROPIC_API_KEY=

# Story mode (mode: story topics) — free stock images from https://www.pexels.com/api/
# Without it, story builds use gradient placeholders.
PEXELS_API_KEY=

# Dashboard login — REQUIRED before exposing the dashboard via tunnel/remote.
# Pick a strong password; without it the dashboard refuses non-localhost binding.
DASHBOARD_USER=admin
DASHBOARD_PASS=

# Fixed-URL remote access via ngrok (free). Your static domain from
# dashboard.ngrok.com -> Domains  (e.g. abc-123.ngrok-free.app). Run once:
#   ngrok config add-authtoken <YOUR_TOKEN>
NGROK_DOMAIN=
